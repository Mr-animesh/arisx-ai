# Google Sheets API
# Download from: https://console.cloud.google.com → Service Accounts → JSON key
GOOGLE_SERVICE_ACCOUNT_JSON=credentials.json

# Your Google Sheet ID (from the URL: docs.google.com/spreadsheets/d/SHEET_ID/edit)
GOOGLE_SHEET_ID=1ySXGSLO0d15cZBXl1o8gudohVCpe5Veb-1a7MyG21Xo

# Optional: News API key for freshness feed (free tier: newsapi.org)
NEWS_API_KEY=your_newsapi_key_here

# Optional: Slack webhook for new program notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Scraper settings
REQUEST_DELAY_SECONDS=2
MAX_RETRIES=3
